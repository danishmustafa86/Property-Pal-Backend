APP_NAME=Real Estate Intelligence Backend
APP_VERSION=0.1.0
ENVIRONMENT=development
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=real_estate

# Clerk (https://dashboard.clerk.com → API Keys)
# Frontend API / JWT issuer, e.g. https://your-app.clerk.accounts.dev (must match JWT "iss")
CLERK_ISSUER=
# Optional: full JWKS URL. If omitted, defaults to {CLERK_ISSUER}/.well-known/jwks.json
CLERK_JWKS_URL=
# Only if you use a custom JWT template with an "aud" claim
CLERK_AUDIENCE=
# Secret key (sk_live_... / sk_test_...) for Clerk Backend API calls from this server
CLERK_SECRET_KEY=

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# AIML API (OpenAI-compatible): https://aimlapi.com — use your AIML key as OPENAI_API_KEY
OPENAI_API_KEY=
LLM_BASE_URL=https://api.aimlapi.com/v1
LLM_MODEL=meta-llama/Meta-Llama-3-70B-Instruct
# Live web research (https://tavily.com)
TAVILY_API_KEY=
# Optional override for macro CSV folder (default: backend/data)
DATA_DIR=
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=800
AGENT_ENABLE_WRITE_TOOLS=true
AGENT_REQUIRE_WRITE_CONFIRMATION=true
AGENT_SUMMARY_TRIGGER_MESSAGES=12
AGENT_SUMMARY_KEEP_LAST_MESSAGES=6
AGENT_SUMMARY_MAX_TOKENS=256
