APP_NAME=Real Estate Intelligence Backend
APP_VERSION=0.1.0
ENVIRONMENT=development
# Local dev (no Atlas):
MONGODB_URI=mongodb://localhost:27017
# Atlas: mongodb+srv://... is fine on most networks. On campus Wi‑Fi the app auto-expands srv →
# standard mongodb:// when possible. If connect still fails, set MONGODB_URI_STANDARD from Atlas
# (Connect → Drivers → "Standard connection string").
# MONGODB_URI_STANDARD=mongodb://user:pass@host1:27017,host2:27017/real_estate?ssl=true&authSource=admin
MONGODB_DB_NAME=real_estate

# Clerk (https://dashboard.clerk.com → API Keys)
CLERK_ISSUER=
CLERK_JWKS_URL=
CLERK_AUDIENCE=
CLERK_SECRET_KEY=

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Google Maps Platform — Places API (New)
GOOGLE_MAPS_API_KEY=
